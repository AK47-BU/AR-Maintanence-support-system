# Server
PORT=3000
NODE_ENV=development

# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/ar-maintenance
# For MongoDB Atlas (cloud): mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ar-maintenance
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ar-maintenance
# JWT Secret - CHANGE THIS to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS - allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
